# 한국은행 ECOS
ECOS_API_KEY=your_ecos_api_key_here

# KOSIS 국가통계포털
KOSIS_API_KEY=your_kosis_api_key_here

# 공공데이터포털 (한국부동산원, 국토교통부 등)
DATA_GO_KR_API_KEY=your_data_go_kr_api_key_here

# DART 전자공시시스템
DART_API_KEY=your_dart_api_key_here

# FRED (Federal Reserve Economic Data)
FRED_API_KEY=your_fred_api_key_here

# Alpha Vantage (글로벌 주식 데이터)
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_api_key_here

# Supabase - Data Think 전용 DB
# (Church Think와 별도 프로젝트 권장)
DATA_THINK_SUPABASE_URL=your_supabase_project_url
DATA_THINK_SUPABASE_KEY=your_supabase_service_role_key

# 수집 엔진 설정
COLLECTION_RETRY_MAX=3
COLLECTION_RETRY_DELAY_MS=2000
COLLECTION_TIMEOUT_MS=30000
LOG_LEVEL=info

# 환경 (development / production)
NODE_ENV=development

# Admin 웹 대시보드 포트 및 비활성화 여부
ADMIN_PORT=3500
SKIP_ADMIN=false

